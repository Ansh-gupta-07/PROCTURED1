{
  "name": "hope-os-kiosk",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "HOPE OS — Secure Examination Kiosk Application Prototype",
  "author": "HOPE OS Dev <admin@hopeos.local>",
  "homepage": "https://github.com/hope-os",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:linux": "vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.exam.hopeos",
    "productName": "HOPE OS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education"
    }
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.12"
  }
}
